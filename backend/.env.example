DATABASE_URL="postgresql://user:password@localhost:5432/caregiver_hub"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Email (optional - for invitations/notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Caregiver Hub <noreply@caregiverhub.com>"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# AWS (for production)
AWS_REGION="us-east-1"
AWS_S3_BUCKET="caregiver-hub-uploads"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
